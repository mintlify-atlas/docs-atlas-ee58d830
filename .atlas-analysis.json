  "keyFeatures": [
    "Multi-role authentication system with Admin, Barber, and Client access levels",
    "Custom barbershop site builder with drag-and-drop components and templates",
    "Real-time appointment booking and scheduling management",
    "Integrated payment processing with Stripe for services and appointments",
    "Google OAuth authentication for seamless user registration",
    "Public barbershop pages accessible via custom slugs",
    "Service catalog management for barbers",
    "Admin dashboard for platform-wide user and barbershop management",
    "Geolocation features for finding nearby barbershops",
    "Sales tracking and analytics for barbers"
  ],
  "publicApiSurface": [
    "POST /api/auth/register - Register new user",
    "POST /api/auth/login - Login with credentials",
    "POST /api/auth/google - Google OAuth login",
    "GET /api/users/profile - Get user profile",
    "PUT /api/users/profile - Update user profile",
    "POST /api/barbershops - Create barbershop",
    "GET /api/barbershops - List barbershops",
    "GET /api/barbershops/:id - Get barbershop by ID",
    "PUT /api/barbershops/:id - Update barbershop",
    "DELETE /api/barbershops/:id - Delete barbershop",
    "GET /api/b/:slug - Public barbershop view by slug",
    "POST /api/services - Create service",
    "GET /api/services/:barbershopId - List services for barbershop",
    "PUT /api/services/:id - Update service",
    "DELETE /api/services/:id - Delete service",
    "POST /api/appointments - Create appointment",
    "GET /api/appointments - List appointments",
    "PUT /api/appointments/:id - Update appointment status",
    "DELETE /api/appointments/:id - Cancel appointment",
    "POST /api/barber/design/site - Create barbershop site",
    "GET /api/barber/design/site/:barbershopId - Get site design",
    "PUT /api/barber/design/section - Update site section",
    "GET /api/templates - Get site templates",
    "POST /api/uploads/site - Upload site assets",
    "POST /api/sales - Create sale record",
    "GET /api/sales/:barbershopId - List sales for barbershop",
    "GET /api/admin/users - Admin: List all users",
    "GET /api/admin/barbershops - Admin: List all barbershops",
    "GET /api/admin/reports - Admin: Generate reports"
  ]
